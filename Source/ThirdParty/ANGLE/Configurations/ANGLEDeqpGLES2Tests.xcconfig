#include "ANGLEDeqp.xcconfig"

PRODUCT_NAME = ANGLEDeqpGLES2Tests;
GCC_PREPROCESSOR_DEFINITIONS = ANGLE_DEQP_GLES2_TESTS $(inherited);
HEADER_SEARCH_PATHS = $(ANGLE_HEADER_PATH_PREFIX)/src/tests $(inherited);
ANGLE_OTHER_LDFLAGS = $(DEQP_LINK_FRAMEWORKS) $(ANGLE_OTHER_LDFLAGS_$(WK_PLATFORM_NAME));
ANGLE_OTHER_LDFLAGS_macosx = -framework Cocoa -framework IOKit -lz;
ANGLE_OTHER_LDFLAGS_maccatalyst = -framework UIKit -framework IOKit -lz;
ANGLE_OTHER_LDFLAGS_iphoneos = -framework UIKit -lz;
ANGLE_OTHER_LDFLAGS_iphonesimulator = $(ANGLE_OTHER_LDFLAGS_iphoneos);
ANGLE_OTHER_LDFLAGS_xros = $(ANGLE_OTHER_LDFLAGS_iphoneos);
ANGLE_OTHER_LDFLAGS_xrsimulator = $(ANGLE_OTHER_LDFLAGS_iphoneos);
ANGLE_OTHER_LDFLAGS_appletvos = $(ANGLE_OTHER_LDFLAGS_iphoneos);
ANGLE_OTHER_LDFLAGS_appletvsimulator = $(ANGLE_OTHER_LDFLAGS_iphoneos);
ANGLE_OTHER_LDFLAGS_watchos = $(ANGLE_OTHER_LDFLAGS_iphoneos);
ANGLE_OTHER_LDFLAGS_watchsimulator = $(ANGLE_OTHER_LDFLAGS_iphoneos);
